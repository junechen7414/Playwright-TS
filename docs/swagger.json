							}
						}
					}
				}
			},
			"put": {
				"tags": ["Account"],
				"summary": "更新帳戶",
				"description": "更新現有帳戶資訊。受限於 SQLRestriction 規則，若帳戶 ID 不存在、已軟刪除或狀態非啟用 \u0027Y\u0027，將拋出 NotFound。若欲將狀態從啟用 \u0027Y\u0027 變更為停用 \u0027N\u0027，會先檢查該帳戶是否仍有關聯訂單，若有則拋出 AccountStillHasOrderCanNotBeDeleteException。",
				"operationId": "updateAccount",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "帳戶 ID",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						},
						"example": 1
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UpdateAccountRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "更新成功"
					},
					"400": {
						"description": "參數驗證失敗或帳戶仍有關聯訂單",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								}
							}
						}
					},
					"404": {
						"description": "帳戶不存在",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": ["Account"],
				"summary": "刪除帳戶",
				"description": "執行帳戶軟刪除。受限於 SQLRestriction 規則，若帳戶 ID 不存在、已軟刪除或狀態非啟用 \u0027Y\u0027，將拋出 NotFound。若該帳戶仍有關聯訂單，則拋出 AccountStillHasOrderCanNotBeDeleteException。",
				"operationId": "deleteAccount",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "帳戶 ID",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						},
						"example": 1
					}
				],
				"responses": {
					"200": {
						"description": "刪除成功"
					},
					"400": {
						"description": "帳戶仍有關聯訂單，無法刪除",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								}
							}
						}
					},
					"404": {
						"description": "帳戶不存在",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								}
							}
						}
					}
				}
			}
		},
		"/product": {
			"get": {
				"tags": ["Product"],
				"summary": "獲取商品列表（分頁）",
				"description": "獲取所有商品的分頁列表。受限於 SQLRestriction 規則，僅會回傳未被軟刪除且銷售狀態為 1001 (AVAILABLE) 的商品。",
				"operationId": "getProductList",
				"parameters": [
					{
						"name": "pageable",
						"in": "query",
						"description": "分頁參數（page\u003d頁碼從0開始, size\u003d每頁筆數, sort\u003d排序欄位,方向）",
						"required": true,
						"schema": {
							"$ref": "#/components/schemas/Pageable"
						},
						"example": "page\u003d0\u0026size\u003d20\u0026sort\u003did,asc"
					}
				],
				"responses": {
					"200": {
						"description": "成功取得商品分頁列表",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PageResponseGetProductListResponse"
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": ["Product"],
				"summary": "新增商品",
				"description": "建立新商品。若已存在同名商品則拋出 ProductAlreadyExistException。成功則新增商品資料，預設銷售狀態為 1001 (AVAILABLE)。",
				"operationId": "createProduct",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateProductRequest"
							}
