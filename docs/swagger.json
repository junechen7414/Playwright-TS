		"/order/account/{accountId}/exists": {
			"get": {
				"tags": ["Order"],
				"summary": "檢查帳戶ID是否存在於任何有效訂單中",
				"description": "判斷帳戶是否有關聯的有效訂單，用於帳戶更新與刪除時的檢核。受限於系統規則，僅會針對未軟刪除且狀態為 1001 (CREATED) 的訂單進行判定。",
				"operationId": "AccountIdIsInOrder",
				"parameters": [
					{
						"name": "accountId",
						"in": "path",
						"description": "帳戶 ID",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						},
						"example": 1
					}
				],
				"responses": {
					"200": {
						"description": "回傳布林值，true 表示有關聯訂單",
						"content": {
							"*/*": {
								"schema": {
									"type": "boolean"
								}
							}
						}
					}
				}
			}
		}
	},
