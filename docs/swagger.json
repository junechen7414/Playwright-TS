				"responses": {
					"200": {
						"description": "成功取得帳戶詳細資訊",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/GetAccountDetailResponse"
								}
							}
						}
					},
					"404": {
						"description": "帳戶不存在",
