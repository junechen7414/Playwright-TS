				"operationId": "processOrderItems",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/ProcessOrderItemsRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "處理成功"
					}
				}
			}
		},
