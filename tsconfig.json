{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./*"],
			"@tests/*": ["./tests/*"],
			"@fixtures/*": ["./fixtures/*"],
			"@pages/*": ["./services/pages/*"]
		},
		/* 進階檢查 */
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noUncheckedSideEffectImports": true,
		"verbatimModuleSyntax": true,

		/* 輸出相關設定 */
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		/* 針對 Node 22 的優化 (通常繼承已有，但可顯式標註) */
		"module": "esnext",
		"moduleResolution": "bundler"
	},
	"include": ["tests/**/*.ts", "services/**/*.ts", "playwright.config.ts"],
	"exclude": ["node_modules", ".github", ".gitignore"]
}
