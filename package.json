{
	"name": "playwright-typescript-automated-project",
	"version": "1.0.0",
	"description": "Playwright TypeScript Automated Testing",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"biome:check": "biome check",
		"biome:fix": "biome check --write",
		"api-spec:update": "openapi-typescript ./docs/swagger.json -o ./schema/api-types.ts",
		"pull-image": "podman compose --file docker-compose.test.yml pull",
		"compose-up": "podman compose --file docker-compose.test.yml up -d",
		"staging-test-all": "set ENV=staging && playwright test",
		"local-test-all": "playwright test",
		"echo test": "echo \"Error: no test specified\" && exit 1"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.57.0",
		"@types/node": "^24.7.2",
		"openapi-typescript": "^7.13.0"
	}
}
